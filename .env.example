# =============================================================================
# Velkor Platform — Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# --- Database ----------------------------------------------------------------
POSTGRES_USER=velkor
POSTGRES_PASSWORD=velkor_secret
POSTGRES_DB=velkor
DATABASE_URL=postgresql://velkor:velkor_secret@postgres:5432/velkor

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# --- MinIO (S3-compatible object storage) ------------------------------------
MINIO_ROOT_USER=velkor
MINIO_ROOT_PASSWORD=velkor_secret
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=velkor
S3_SECRET_KEY=velkor_secret
S3_BUCKET=velkor-documents

# --- Auth / JWT --------------------------------------------------------------
PLATFORM_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_SECRET=change-me-to-a-random-64-char-string

# --- LLM Providers (at least one required) -----------------------------------
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Search Provider (optional — DuckDuckGo works without keys) --------------
# TAVILY_API_KEY=
# BRAVE_API_KEY=
# SERPER_API_KEY=
# PERPLEXITY_API_KEY=          # pplx-* for direct, or use OPENROUTER_API_KEY

# --- Service Ports -----------------------------------------------------------
CORE_PORT=3001
API_PORT=3000
WEB_PORT=80

# --- CORS (for local dev without nginx) --------------------------------------
CORS_ORIGIN=http://localhost:8080
